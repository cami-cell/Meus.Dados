CREATE DATABASE ControleLoja;
USE ControleLoja;

CREATE TABLE CLIENTES (
    id_cliente INT NOT NULL AUTO_INCREMENT,
    nome VARCHAR(100) NOT NULL,
    email VARCHAR(100) NOT NULL,
    data_cadastro DATE NOT NULL,
    PRIMARY KEY (id_cliente)
);

