DELIMITER $$

CREATE FUNCTION Fn_TotalClientesPorDia (data_pesquisa DATE)
RETURNS INT
DETERMINISTIC
BEGIN
    DECLARE total_cadastros INT;

    SELECT COUNT(*) INTO total_cadastros
    FROM CLIENTES
    WHERE data_cadastro = data_pesquisa;

    RETURN total_cadastros;
END$$

DELIMITER ;

SELECT Fn_TotalClientesPorDia('2026-06-30') AS 'Clientes Cadastrados no Dia';
